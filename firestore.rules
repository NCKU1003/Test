rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidSharedPhoto(data) {
      return data.id is string 
        && data.id.size() <= 64
        && data.spotId is string 
        && data.spotId.size() <= 64
        && data.photoData is string 
        && data.photoData.size() <= 1000000
        && data.uploadedAt is timestamp
        && data.keys().hasAll(['id', 'spotId', 'photoData', 'uploadedAt'])
        && data.keys().size() == 4;
    }

    function isValidWishItem(data) {
      return data.id is string
        && data.id.size() <= 64
        && data.name is string
        && data.name.size() <= 150
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000))
        && (!('category' in data) || (data.category is string && data.category.size() <= 64))
        && data.author is string
        && data.author.size() <= 64
        && data.likes is int
        && data.likedBy is list
        && (!('gmapUrl' in data) || (data.gmapUrl is string && data.gmapUrl.size() <= 2000))
        && data.createdAt is timestamp
        && data.keys().hasAll(['id', 'name', 'author', 'likes', 'likedBy', 'createdAt'])
        && data.keys().size() >= 6 && data.keys().size() <= 9;
    }

    function isValidCustomSpot(data) {
      return data.id is string
        && data.id.size() <= 64
        && data.dayNumber is int
        && data.dayNumber >= 1 && data.dayNumber <= 10
        && data.time is string
        && data.time.size() <= 10
        && data.name is string
        && data.name.size() <= 150
        && (!('description' in data) || (data.description is string && data.description.size() <= 1000))
        && data.type is string
        && data.type.size() <= 64
        && (!('gmapUrl' in data) || (data.gmapUrl is string && data.gmapUrl.size() <= 2000))
        && (!('wishId' in data) || (data.wishId is string && data.wishId.size() <= 64))
        && data.createdAt is timestamp
        && data.keys().hasAll(['id', 'dayNumber', 'time', 'name', 'type', 'createdAt'])
        && data.keys().size() >= 6 && data.keys().size() <= 9;
    }

    function isValidGuideItem(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.categoryId is string
        && data.categoryId.size() <= 64
        && data.name is string
        && data.name.size() <= 150
        && (!('desc' in data) || (data.desc is string && data.desc.size() <= 1000))
        && data.checked is bool
        && (!('tag' in data) || (data.tag is string && data.tag.size() <= 64))
        && (!('link' in data) || (data.link is string && data.link.size() <= 1000))
        && data.createdAt is timestamp
        && data.keys().hasAll(['id', 'categoryId', 'name', 'checked', 'createdAt'])
        && data.keys().size() >= 5 && data.keys().size() <= 9;
    }

    // Shared Photos Rules
    match /shared_photos/{photoId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidId(photoId) 
        && incoming().id == photoId 
        && isValidId(incoming().spotId)
        && isValidSharedPhoto(incoming())
        && incoming().uploadedAt == request.time;
        
      allow update: if isValidId(photoId) 
        && incoming().id == existing().id
        && incoming().spotId == existing().spotId
        && isValidSharedPhoto(incoming())
        && incoming().uploadedAt == request.time;
        
      allow delete: if isValidId(photoId);
    }

    // Wishlist Rules
    match /wishlist/{wishId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidId(wishId)
        && incoming().id == wishId
        && isValidWishItem(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isValidId(wishId)
        && incoming().id == existing().id
        && isValidWishItem(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy'])
          ||
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'notes', 'category', 'gmapUrl'])
        );
        
      allow delete: if true;
    }

    // Custom Spots Rules
    match /custom_spots/{spotId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidId(spotId)
        && incoming().id == spotId
        && isValidCustomSpot(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isValidId(spotId)
        && incoming().id == existing().id
        && isValidCustomSpot(incoming())
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if true;
    }

    // Guide Items Rules
    match /guide_items/{itemId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isValidId(itemId)
        && incoming().id == itemId
        && isValidGuideItem(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isValidId(itemId)
        && incoming().id == existing().id
        && isValidGuideItem(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['checked'])
          ||
          incoming().diff(existing()).affectedKeys().hasOnly(['categoryId', 'name', 'desc', 'tag', 'checked'])
        );
        
      allow delete: if true;
    }
  }
}
